# Desenvolvimento local
DATABASE_URL="file:./dev.db"

# Railway demo — configurar via painel do Railway, nao versionar
# DATABASE_URL="file:/data/nexis-demo.db"

NEXT_PUBLIC_AUDIO_INPUT_ENABLED="false"
AUDIO_TRANSCRIPTION_PROVIDER="mock"
BETKOL_CPU_COMMAND=""
BETKOL_CPU_TIMEOUT_MS="10000"

# IA externa — Groq (https://console.groq.com) ou outro provedor compativel com OpenAI
# Configure AI_API_KEY apenas via Railway dashboard ou .env.local; nunca versionar chave real
# Com AI_API_KEY vazio o app cai automaticamente para o parser rule-based
AI_ASSISTANT_ENABLED="true"
AI_ASSISTANT_REVIEW_PASS_ENABLED="false"
AI_PROVIDER="openai-compatible"
AI_BASE_URL="https://api.groq.com/openai/v1"
AI_MODEL="llama-3.1-8b-instant"
AI_API_KEY=""
AI_TIMEOUT_MS="15000"
